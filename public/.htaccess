# ============================================================
#  Cache Control - Alleefrance Web
#  Evita que el navegador muestre versiones antiguas del sitio
# ============================================================

# --- Archivos HTML: nunca cachear (siempre pedir versión nueva) ---
<FilesMatch "\.(html|htm)$">
  Header set Cache-Control "no-cache, no-store, must-revalidate"
  Header set Pragma "no-cache"
  Header set Expires "0"
</FilesMatch>

# --- Assets de Next.js con hash en el nombre: cachear 1 año ---
# Estos archivos tienen un hash único (ej: abc123.js) generado en cada build
# Por eso es seguro cachearlos por mucho tiempo
<FilesMatch "\.(js|css|woff|woff2|ttf|eot)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# --- Imágenes y fuentes: cachear 30 días ---
<FilesMatch "\.(webp|png|jpg|jpeg|gif|svg|ico|avif)$">
  Header set Cache-Control "public, max-age=2592000"
</FilesMatch>

# --- Habilitar el módulo de headers si no está activo ---
<IfModule mod_headers.c>
  # Ya incluido arriba, esto asegura compatibilidad
</IfModule>
